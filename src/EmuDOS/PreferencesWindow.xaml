<Window x:Class="EmuDOS.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EmuDOS Preferences" Height="560" Width="580"
        Background="{StaticResource BgPrimary}" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinHeight="420" MinWidth="480">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
        </Style>
        <Style x:Key="Heading" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <TabControl x:Name="Tabs" Background="{StaticResource BgPrimary}" BorderThickness="0" Padding="0">
        <TabItem x:Name="GameOptionsTab" Header="Game Options">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18">
                    <TextBlock x:Name="GameTitle" Style="{StaticResource Heading}"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,6"
                               Text="Saved for this game only — overrides the catalog defaults and survives catalog updates."/>

                    <TextBlock Text="CPU speed" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="CpuCyclesMode" Width="150" Foreground="{StaticResource TextPrimary}" SelectionChanged="OnCyclesModeChanged"/>
                        <TextBox x:Name="FixedCycles" Width="90" Margin="10,0,0,0"/>
                        <TextBlock x:Name="CyclesHint" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Text="cycles (lower if a game runs too fast)"/>
                    </StackPanel>

                    <TextBlock Text="Machine / graphics" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="MachineTypeBox" Width="200" HorizontalAlignment="Left" Foreground="{StaticResource TextPrimary}"/>

                    <TextBlock Text="Memory (MB)" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="MemoryBox" Width="120" HorizontalAlignment="Left" Foreground="{StaticResource TextPrimary}"/>

                    <TextBlock Text="Sound card" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="SoundCardBox" Width="200" HorizontalAlignment="Left" Foreground="{StaticResource TextPrimary}"/>

                    <TextBlock Text="MIDI music" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="MidiBox" Width="200" HorizontalAlignment="Left" Foreground="{StaticResource TextPrimary}"/>

                    <CheckBox x:Name="AspectBox" Content="Correct aspect ratio" Margin="0,16,0,0"/>

                    <TextBlock Text="Display (EmuDOS)" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,18,0,2"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,6"
                               Text="Applied by EmuDOS to the picture — the core has no brightness/gamma. Raise gamma to lift a too-dark game."/>

                    <DockPanel Margin="0,4,0,0">
                        <TextBlock DockPanel.Dock="Left" Text="Brightness" Width="80" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" x:Name="BrightnessValue" Width="44" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                        <Slider x:Name="BrightnessSlider" Minimum="0.5" Maximum="1.5" Value="1"
                                SmallChange="0.05" LargeChange="0.1" VerticalAlignment="Center"
                                ValueChanged="OnDisplaySliderChanged"/>
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock DockPanel.Dock="Left" Text="Gamma" Width="80" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" x:Name="GammaValue" Width="44" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                        <Slider x:Name="GammaSlider" Minimum="0.5" Maximum="2.0" Value="1"
                                SmallChange="0.05" LargeChange="0.1" VerticalAlignment="Center"
                                ValueChanged="OnDisplaySliderChanged"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Save" Click="OnSaveGameOptions"/>
                        <Button Content="Reset to catalog default" Margin="10,0,0,0" Click="OnResetGameOptions"/>
                        <TextBlock x:Name="GameOptionsStatus" Foreground="#9FE0A0" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Snaps">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18">
                    <TextBlock Text="ScreenScraper" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,10"
                               Text="Log in with your screenscraper.fr account for higher box-art download limits. (Optional — basic art works without it.)"/>

                    <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="SsUser"/>

                    <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="SsPass" Padding="6,5" Background="{StaticResource BgTertiary}"
                                 Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderNormal}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="SsLogin" Content="Log in" Click="OnLoginScreenScraper"/>
                        <TextBlock x:Name="SsStatus" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <Separator Margin="0,22" Background="{StaticResource BorderNormal}"/>

                    <TextBlock Text="SteamGridDB" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,10"
                               Text="Paste your API key from steamgriddb.com — used as a fallback art source for games ScreenScraper doesn't have."/>

                    <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="SgdbKey"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="SgdbLogin" Content="Log in" Click="OnLoginSteamGridDb"/>
                        <TextBlock x:Name="SgdbStatus" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Media">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18">
                    <TextBlock Text="Screenshots" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,10"
                               Text="Press F12 in-game to capture a screenshot."/>

                    <TextBlock Text="Save folder" Style="{StaticResource FieldLabel}"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse…" Margin="8,0,0,0" Padding="14,5" Click="OnBrowseScreenshotFolder"/>
                        <TextBox x:Name="ScreenshotFolderBox"/>
                    </DockPanel>

                    <TextBlock Text="Capture size" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                    <ComboBox x:Name="ScreenshotSizeBox" Width="240" HorizontalAlignment="Left" Foreground="{StaticResource TextPrimary}">
                        <ComboBoxItem Content="Original (game's native pixels)"/>
                        <ComboBoxItem Content="Window size (as displayed)"/>
                    </ComboBox>

                    <Separator Margin="0,22" Background="{StaticResource BorderNormal}"/>

                    <TextBlock Text="Video recording" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,10"
                               Text="Press F9 in-game to start/stop recording. Needs FFmpeg (install it from the Downloads tab)."/>

                    <TextBlock Text="Save folder" Style="{StaticResource FieldLabel}"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse…" Margin="8,0,0,0" Padding="14,5" Click="OnBrowseVideoFolder"/>
                        <TextBox x:Name="VideoFolderBox"/>
                    </DockPanel>

                    <TextBlock Text="Quality" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                    <ComboBox x:Name="VideoQualityBox" Width="240" HorizontalAlignment="Left" Foreground="{StaticResource TextPrimary}">
                        <ComboBoxItem Content="Low"/>
                        <ComboBoxItem Content="Medium"/>
                        <ComboBoxItem Content="High"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <Button Content="Save" Click="OnSaveMedia" Padding="18,6"/>
                        <TextBlock x:Name="MediaStatus" Foreground="#9FE0A0" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Hotkeys">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18">
                    <TextBlock Text="Hotkeys" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,14"
                               Text="Click a box and press the key you want it bound to. Press Esc to reset it to the default."/>

                    <TextBlock Text="Screenshot" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="HotkeyScreenshot" Width="200" HorizontalAlignment="Left" IsReadOnly="True"
                             Cursor="Hand" PreviewKeyDown="OnHotkeyCapture"/>

                    <TextBlock Text="Record video" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                    <TextBox x:Name="HotkeyRecord" Width="200" HorizontalAlignment="Left" IsReadOnly="True"
                             Cursor="Hand" PreviewKeyDown="OnHotkeyCapture"/>

                    <TextBlock Text="Mouse lock" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                    <TextBox x:Name="HotkeyMouseLock" Width="200" HorizontalAlignment="Left" IsReadOnly="True"
                             Cursor="Hand" PreviewKeyDown="OnHotkeyCapture"/>
                    <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,4,0,0"
                               Text="Middle-click always toggles mouse lock too."/>

                    <TextBlock Text="In-game menu (swap CDs/disks)" Style="{StaticResource FieldLabel}" Margin="0,12,0,0"/>
                    <TextBox x:Name="HotkeyMenu" Width="200" HorizontalAlignment="Left" IsReadOnly="True"
                             Cursor="Hand" PreviewKeyDown="OnHotkeyCapture"/>
                    <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,4,0,0"
                               Text="Opens dosbox's menu — insert/eject discs, on-screen keyboard."/>

                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <Button Content="Save" Click="OnSaveHotkeys" Padding="18,6"/>
                        <TextBlock x:Name="HotkeysStatus" Foreground="#9FE0A0" VerticalAlignment="Center" Margin="14,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="Downloads">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18">
                    <TextBlock Text="Downloads" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" Margin="0,0,0,14"
                               Text="Components are fetched on demand rather than bundled (for size and licensing). The core is required; the catalog and MT-32 module are optional."/>
                    <ItemsControl x:Name="DownloadList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderNormal}"
                                        BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource Muted}" FontSize="11" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusBrush}" FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="{Binding ActionText}" VerticalAlignment="Center"
                                                Padding="16,6" IsEnabled="{Binding CanDownload}" Click="OnDownloadClick"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,6,0,16" Background="{StaticResource BorderNormal}"/>

                    <TextBlock Text="Roland MT-32 ROMs" Style="{StaticResource Heading}" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,8"
                               Text="Roland's copyrighted firmware — we can't distribute it. Supply your own by dragging the .rom files (MT-32 or CM-32L), or a folder containing them, anywhere onto EmuDOS."/>
                    <TextBlock x:Name="Mt32RomStatus" FontSize="11"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
