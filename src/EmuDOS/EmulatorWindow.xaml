<Window x:Class="EmuDOS.EmulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EmuDOS" Width="800" Height="640"
        Background="Black" WindowStartupLocation="CenterScreen"
        Focusable="True"
        KeyDown="OnKeyDown" KeyUp="OnKeyUp"
        MouseMove="OnMouseMove" MouseDown="OnMouseButton" MouseUp="OnMouseButton"
        Closing="OnClosing">
    <Image x:Name="Screen" Stretch="Uniform"
           RenderOptions.BitmapScalingMode="NearestNeighbor"
           SnapsToDevicePixels="True"/>
</Window>
