<Window x:Class="EmuDOS.EmulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EmuDOS" Width="800" Height="640" Icon="/Assets/EmuDOS.ico"
        Background="Black" WindowStartupLocation="CenterScreen"
        Focusable="True"
        PreviewKeyDown="OnKeyDown" PreviewKeyUp="OnKeyUp"
        MouseMove="OnMouseMove" MouseDown="OnMouseButton" MouseUp="OnMouseButton"
        MouseWheel="OnMouseWheel"
        Closing="OnClosing">
    <Grid>
        <Image x:Name="Screen" Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               SnapsToDevicePixels="True"/>
        <TextBlock x:Name="Hint" Visibility="Collapsed" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0"
                   Foreground="#FFEBD43E" FontSize="14" FontWeight="SemiBold"
                   Background="#C0000000" Padding="14,6"/>
        <TextBlock x:Name="RecIndicator" Visibility="Collapsed" IsHitTestVisible="False" Text="● REC"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,16,0"
                   Foreground="#FFE03535" FontSize="14" FontWeight="Bold"
                   Background="#A0000000" Padding="8,3"/>
    </Grid>
</Window>
