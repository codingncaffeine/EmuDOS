<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\EmuDOS.Core\EmuDOS.Core.csproj" />
    <ProjectReference Include="..\EmuDOS.Metadata\EmuDOS.Metadata.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.2" />
  </ItemGroup>

  <!-- App-owned art embedded in the exe (the shelf backdrop). -->
  <ItemGroup>
    <Resource Include="..\..\Assets\bookshelf.png" Link="Assets\bookshelf.png" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

</Project>
