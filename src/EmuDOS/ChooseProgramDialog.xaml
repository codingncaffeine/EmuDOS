<Window x:Class="EmuDOS.ChooseProgramDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" SizeToContent="Height" Width="460"
        Background="{StaticResource BgPrimary}" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border BorderBrush="{StaticResource BorderNormal}" BorderThickness="1">
        <StackPanel Margin="24,22">
            <TextBlock x:Name="TitleText" Foreground="{StaticResource TextPrimary}"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Pick the program to launch. A game program becomes the default for this game; setup tools just run once."/>
            <ListBox x:Name="ExeList" MaxHeight="280"
                     Background="{StaticResource BgSecondary}" Foreground="{StaticResource TextPrimary}"
                     BorderBrush="{StaticResource BorderNormal}" BorderThickness="1"
                     MouseDoubleClick="OnListDoubleClick"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Click="OnCancel" Padding="18,6"/>
                <Button Content="Run" Click="OnRunClick" Margin="10,0,0,0"
                        Padding="18,6" Foreground="{StaticResource Accent}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
