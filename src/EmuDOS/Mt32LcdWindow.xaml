<Window x:Class="EmuDOS.Mt32LcdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MT-32" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        SizeToContent="WidthAndHeight" Focusable="False"
        MouseLeftButtonDown="OnDrag">
    <!-- A little Roland MT-32 unit: dark bezel + amber dot-matrix LCD. -->
    <Border CornerRadius="7" Background="#1A1A1C" BorderBrush="#000000" BorderThickness="1" Padding="10">
        <StackPanel>
            <TextBlock Text="Roland MT-32" Foreground="#6A6A6E" FontSize="9" FontWeight="SemiBold"
                       Margin="2,0,0,5" HorizontalAlignment="Left"/>
            <Border Background="#11160A" CornerRadius="3" Padding="14,9" BorderBrush="#05080B" BorderThickness="2">
                <TextBlock x:Name="Lcd" Text="" MinWidth="330"
                           FontFamily="/Assets/Fonts/#DotGothic16" FontSize="22"
                           Foreground="#FFC24A" TextOptions.TextRenderingMode="Aliased">
                    <TextBlock.Effect>
                        <BlurEffect Radius="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Border>
        </StackPanel>
    </Border>
</Window>
