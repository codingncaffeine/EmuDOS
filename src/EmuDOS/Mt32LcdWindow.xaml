<Window x:Class="EmuDOS.Mt32LcdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:EmuDOS.Controls"
        Title="MT-32" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" Focusable="False"
        MouseLeftButtonDown="OnDrag" MouseWheel="OnScaleWheel">
    <!-- The Roland MT-32 photo at native size in a Viewbox (scroll-wheel resizes it, aspect locked);
         our dot-matrix LCD is overlaid on the glass area. -->
    <Viewbox x:Name="Scaler" Width="600" Stretch="Uniform">
        <Canvas Width="1184" Height="471">
            <Image Source="/Assets/roland.png" Width="1184" Height="471"/>
            <ctrl:Mt32LcdControl x:Name="Lcd" Canvas.Left="160" Canvas.Top="150" Width="560" Height="236"/>
        </Canvas>
    </Viewbox>
</Window>
