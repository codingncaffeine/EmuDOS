<Window x:Class="EmuDOS.GameDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EmuDOS" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowState="Maximized" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner" KeyDown="OnKeyDown">

    <Grid>
        <!-- Scrim: click anywhere outside the card to dismiss (static color so hit-testing works). -->
        <Border x:Name="Scrim" Background="#99000000" MouseDown="OnScrimDown"/>

        <Border Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource BorderNormal}"
                BorderThickness="1" CornerRadius="10" Width="660" MaxHeight="600"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: art + title + stats -->
                <Grid Grid.Row="0" Margin="22,22,22,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="150" Height="190" Background="#22000000" CornerRadius="4">
                        <Image x:Name="ArtImage" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="18,2,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" Foreground="{StaticResource TextPrimary}" FontSize="21"
                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock x:Name="StatsText" Foreground="{StaticResource TextSecondary}" FontSize="12"
                                   Margin="0,12,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- Body: video snap (top) + metadata (scrolls). -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Snap: box-art placeholder until the video downloads, then crossfade to the loop. -->
                    <Border x:Name="SnapArea" Grid.Row="0" Width="360" Height="270" Margin="22,4,22,10"
                            HorizontalAlignment="Center" Background="#22000000"
                            BorderBrush="{StaticResource BorderNormal}" BorderThickness="1"
                            CornerRadius="4" Visibility="Collapsed" ClipToBounds="True">
                        <Grid>
                            <Image x:Name="SnapPlaceholder" Stretch="Uniform"/>
                            <Image x:Name="SnapVideo" Stretch="Uniform" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="22,0">
                        <StackPanel x:Name="BodyPanel"/>
                    </ScrollViewer>
                </Grid>

                <!-- Actions -->
                <Border Grid.Row="2" Background="{StaticResource BgPrimary}" CornerRadius="0,0,10,10" Padding="16,12">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶  Play" Padding="24,8" FontWeight="SemiBold" Click="OnPlay"/>
                            <Button x:Name="FavButton" Padding="16,8" Margin="10,0,0,0" Click="OnFavorite"/>
                            <Button Content="…" Padding="18,8" Margin="10,0,0,0" Click="OnMore"/>
                        </StackPanel>
                        <Button Content="Close" Padding="16,8" HorizontalAlignment="Right" Click="OnClose"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
