<Window x:Class="EmuDOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EmuDOS.ViewModels"
        xmlns:controls="clr-namespace:EmuDOS.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="EmuDOS" Height="760" Width="595"
        Background="#1A1411" WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- The library: one bookcase wide, repeating only vertically, scrolling down. -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Width="561" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Border.Background>
                    <ImageBrush ImageSource="/Assets/bookshelf.png" TileMode="Tile"
                                Stretch="None" AlignmentX="Left" AlignmentY="Top"
                                Viewport="0,0,561,645" ViewportUnits="Absolute"/>
                </Border.Background>

                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:ShelfPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#D9B98A" CornerRadius="2"
                                    BorderBrush="#3A2A1C" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonUp="OnGameClick"
                                    ToolTip="{Binding Title}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.55"/>
                                </Border.Effect>
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap"
                                           TextAlignment="Center" Foreground="#2A1B10"
                                           FontSize="9" FontWeight="SemiBold" Margin="3"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </ScrollViewer>

        <!-- Status: hidden unless importing / downloading / a problem. -->
        <Border Grid.Row="1" Background="#2A211B"
                Visibility="{Binding ShowStatus, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="14,6">
                <TextBlock Text="{Binding Status}" Foreground="#C8B89C" VerticalAlignment="Center"/>
                <ProgressBar Width="120" Height="6" IsIndeterminate="True"
                             HorizontalAlignment="Right"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
