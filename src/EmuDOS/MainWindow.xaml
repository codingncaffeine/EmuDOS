<Window x:Class="EmuDOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EmuDOS.ViewModels"
        xmlns:controls="clr-namespace:EmuDOS.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="EmuDOS" Height="840" Width="1458"
        Icon="pack://application:,,,/Assets/EmuDOS.ico"
        MinWidth="1458" MaxWidth="1458"
        Background="{StaticResource BgPrimary}" WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver"
        PreviewKeyDown="OnWindowKeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ContextMenu>
            <!-- Library-wide actions (right-click empty shelf space). The 2D/3D default lives in
                 Preferences → Snaps; per-game 2D/3D is on each game's own right-click menu. -->
            <ContextMenu>
                <MenuItem Header="Download missing art" Click="OnDownloadMissingArt"/>
                <MenuItem Header="Download 3D box art (all games)" Click="OnDownload3DArtAll"/>
                <MenuItem Header="Preferences…" Click="OnPreferences"/>
            </ContextMenu>
        </Grid.ContextMenu>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- The library: the bookcase, width locked, repeating vertically. The bookshelf fills
             at least the viewport (so empty shelves always show) and grows as games are added. -->
        <ScrollViewer Grid.Row="0" x:Name="Scroller"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Width="1425" HorizontalAlignment="Center" VerticalAlignment="Top"
                    MinHeight="{Binding ViewportHeight, ElementName=Scroller}">
                <Border.Background>
                    <ImageBrush ImageSource="/Assets/bookshelf2.png" TileMode="Tile"
                                Stretch="None" AlignmentX="Left" AlignmentY="Top"
                                Viewport="0,0,1425,671" ViewportUnits="Absolute"/>
                </Border.Background>

                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:ShelfPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Box sized to the cover's real aspect, so art fills it with no
                                 brown letterbox; the placeholder shows only when there's no art. -->
                            <Grid Width="{Binding BoxWidth}" Height="{Binding BoxHeight}"
                                  Cursor="Hand" ToolTip="{Binding Title}"
                                  MouseLeftButtonDown="OnBoxMouseDown"
                                  MouseMove="OnBoxMouseMove"
                                  MouseLeftButtonUp="OnBoxMouseUp"
                                  MouseRightButtonUp="OnBoxRightClick"
                                  MouseEnter="OnBoxMouseEnter" MouseLeave="OnBoxMouseLeave"
                                  AllowDrop="True" DragOver="OnBoxArtDragOver" Drop="OnBoxArtDrop"
                                  Background="Transparent">
                                <Grid.Effect>
                                    <DropShadowEffect BlurRadius="7" ShadowDepth="3" Opacity="0.55"/>
                                </Grid.Effect>
                                <!-- Brown placeholder shows ONLY when there's no cover. With art it
                                     collapses, so a 3D box's transparent corners reveal the shelf wood
                                     behind instead of a brown rectangle. -->
                                <Border Background="#D9B98A" CornerRadius="2"
                                        BorderBrush="#3A2A1C" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Cover}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap"
                                               TextAlignment="Center" Foreground="#2A1B10"
                                               FontSize="11" FontWeight="SemiBold" Margin="4"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Image Source="{Binding Cover}" Stretch="Fill"/>
                                <Border BorderBrush="#E03535" BorderThickness="3" CornerRadius="2"
                                        Background="#33E03535"
                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="★" FontSize="15" Foreground="#E03535"
                                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,4,0"
                                           Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.9" Color="#000000"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </ScrollViewer>

        <!-- Library filter (Ctrl+F): a themed box over the shelf with search + genre/year/favorites. -->
        <Border Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center" Panel.ZIndex="10"
                Background="{StaticResource BgSecondary}" BorderBrush="#E03535" BorderThickness="1"
                CornerRadius="6" Margin="0,10,0,0" Padding="10,8"
                Visibility="{Binding IsFilterOpen, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                           Margin="2,0,10,0" FontWeight="SemiBold"/>
                <TextBox x:Name="FilterSearch" Width="200" VerticalAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <ComboBox Width="150" Margin="8,0,0,0" VerticalAlignment="Center"
                          ItemsSource="{Binding Genres}" SelectedItem="{Binding SelectedGenre}"/>
                <ComboBox Width="110" Margin="8,0,0,0" VerticalAlignment="Center"
                          ItemsSource="{Binding Decades}" SelectedItem="{Binding SelectedDecade}"/>
                <CheckBox Content="Favorites" Margin="10,0,0,0" VerticalAlignment="Center"
                          Foreground="{StaticResource TextPrimary}" IsChecked="{Binding FavoritesOnly}"/>
                <Button Content="✕" Margin="10,0,2,0" Padding="8,2" Click="OnCloseFilter"
                        Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderThickness="0"
                        Cursor="Hand" ToolTip="Close (Esc)"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1">
            <!-- Update notice: shown when a newer release is on GitHub; click to open the download. -->
            <Button Command="{Binding InstallUpdateCommand}" Cursor="Hand"
                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E03535" Padding="14,7">
                            <TextBlock Text="{Binding UpdateMessage}" Foreground="White" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Status: hidden unless importing / downloading / a problem. -->
            <Border Background="{StaticResource BgSecondary}"
                    Visibility="{Binding ShowStatus, Converter={StaticResource BoolToVisibility}}">
                <Grid Margin="14,6">
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                    <ProgressBar Width="120" Height="6" IsIndeterminate="True"
                                 HorizontalAlignment="Right"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Border>

            <!-- Cloud sync: its own line so launch art/metadata status doesn't clobber it. -->
            <Border Background="{StaticResource BgSecondary}" Padding="14,5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CloudSyncStatus}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding CloudSyncStatus}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
            </Border>
        </StackPanel>

        <!-- Hover preview: a Trinitron monitor showing the game's video snap (video behind the frame's
             transparent screen). Positioned + filled in code on hover. -->
        <Popup x:Name="HoverPopup" AllowsTransparency="True" StaysOpen="True" IsHitTestVisible="False"
               Placement="Right" PopupAnimation="Fade">
            <Grid Width="360" Height="345">
                <Grid.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.6"/>
                </Grid.Effect>
                <Image x:Name="HoverVideo" Margin="41,38,40,80" Stretch="Fill"
                       RenderOptions.BitmapScalingMode="LowQuality"/>
                <Image Source="/Assets/monitor.png" Stretch="Fill"/>
            </Grid>
        </Popup>
    </Grid>
</Window>
